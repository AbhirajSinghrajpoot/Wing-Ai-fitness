# ─── ArogyaMitra Environment Variables ─────────────────
# Copy this file to .env and fill in your own values.
# Never commit your actual .env file to version control.

# ─── AI Services (at least one is required) ───────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── YouTube Data API (optional, for video discovery) ─
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Security ────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# ─── Database ────────────────────────────────────────
# Local: arogyamitra.db  |  Render: /opt/render/project/src/arogyamitra.db
DATABASE_URL=arogyamitra.db

# ─── Google OAuth 2.0 ────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── GitHub OAuth ────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ─── App Settings ────────────────────────────────────
# Local: http://localhost:3000  |  Production: your deployed URL
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# ─── Clerk Authentication ────────────────────────────
# Required for backend auth middleware
# For Vite/React frontend, set this key in VITE_CLERK_PUBLISHABLE_KEY below.
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# ─── Frontend (Vite build-time variables) ────────────
VITE_API_BASE_URL=http://localhost:3000
# Currently unused in frontend code, kept for future OAuth UI hooks
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
# Required for frontend app boot
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
